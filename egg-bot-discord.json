{
        "meta": { "version": "PTDL_v2" },
            "exported_at": "2026-04-18T10:30:00+07:00",
                "name": "NodeJS Bot Discord",
                    "author": "Nino",
                        "description": "Jalankan bot Discord pakai NodeJS 20",
                            "docker_images": {
                                    "Node 20": "ghcr.io/pterodactyl/yolks:nodejs_20"
                                        },
                                            "startup": "if [[ -d .git ]] && [[ {{AUTO_UPDATE}} == \"1\" ]]; then git pull; fi; if [[ ! -z ${NODE_PACKAGES} ]]; then npm install ${NODE_PACKAGES}; fi; if [[ ! -z ${UNNODE_PACKAGES} ]]; then npm uninstall ${UNNODE_PACKAGES}; fi; if [ -f /home/container/package.json ]; then npm install; fi; node {{BOT_JS_FILE}}",
                                                "config": {
                                                        "files": "{}",
                                                                "startup": { "done": "Logged in as" },
                                                                        "logs": "{}",
                                                                                "stop": "^C"
                                                                                    },
                                                                                        "scripts": {
                                                                                                "installation": {
                                                                                                            "script": "#!/bin/bash\r\napt update\r\napt install -y git\r\ncd /mnt/server\r\nif [[ \"${GIT_ADDRESS}\" != *\"https://\"* ]]; then GIT_ADDRESS=\"https://github.com/${GIT_ADDRESS}\"; fi\r\nif [ -z ${USERNAME} ] && [ -z ${ACCESS_TOKEN} ]; then\r\n    echo -e \"using anon\";\r\n    GIT_ADDRESS=\"${GIT_ADDRESS}\";\r\nelse\r\n    GIT_ADDRESS=\"https://${USERNAME}:${ACCESS_TOKEN}@${GIT_ADDRESS#https://}\";\r\nfi\r\ngit clone ${GIT_ADDRESS} .\r\nif [[ -f /mnt/server/package.json ]]; then\r\n    /usr/local/bin/npm install\r\nfi",
                                                                                                                        "container": "ghcr.io/pterodactyl/installers:debian",
                                                                                                                                    "entrypoint": "bash"
                                                                                                                                            }
                                                                                                                                                },
                                                                                                                                                    "variables": [
                                                                                                                                                            {
                                                                                                                                                                        "name": "Bot JS File",
                                                                                                                                                                                    "description": "File utama bot, contoh: index.js",
                                                                                                                                                                                                "env_variable": "BOT_JS_FILE",
                                                                                                                                                                                                            "default_value": "index.js",
                                                                                                                                                                                                                        "user_viewable": true,
                                                                                                                                                                                                                                    "user_editable": true,
                                                                                                                                                                                                                                                "rules": "required|string|max:50"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                            "name": "Git Address",
                                                                                                                                                                                                                                                                                        "description": "Link repo GitHub bot kamu",
                                                                                                                                                                                                                                                                                                    "env_variable": "GIT_ADDRESS",
                                                                                                                                                                                                                                                                                                                "default_value": "",
                                                                                                                                                                                                                                                                                                                            "user_viewable": true,
                                                                                                                                                                                                                                                                                                                                        "user_editable": true,
                                                                                                                                                                                                                                                                                                                                                    "rules": "nullable|string|max:200"
                                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                                                                                                                                                                }
}